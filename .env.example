# --- Login credentials ---
# Do NOT edit these by hand. Set/change them by running, from the project root:
#   python -m backend.set_password <username> <new-password>
# It writes these three keys into your real .env file (hashing the password).
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=
AUTH_SALT=

# --- Current evaluation cycle ---
CURRENT_CYCLE_FY=FY26

# --- Vercel storage (only needed when deploying on Vercel) ---
# Add the "KV" and "Blob" integrations to this project from the Vercel
# dashboard's Storage tab; Vercel then injects these automatically — you
# don't need to set them by hand. Locally (start.bat/start.sh), leave these
# blank and the app uses data/ on local disk instead.
BLOB_READ_WRITE_TOKEN=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Microsoft Graph API (client credentials flow) ---
# Required if EMAIL_PROVIDER=graph. App registration needs Mail.Send (application) permission,
# admin-consented, and a mailbox specified by GRAPH_SENDER_UPN to send as.
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SENDER_UPN=reports@yourcompany.com

# --- Gmail SMTP fallback (dedicated sending account only) ---
# Required if EMAIL_PROVIDER=gmail_smtp. Use a Google App Password, not the account password.
GMAIL_SMTP_USER=
GMAIL_SMTP_APP_PASSWORD=

# graph | gmail_smtp
EMAIL_PROVIDER=graph

# Fallback recipient list applied when a contractor has no email on file or the
# 80% threshold check fails at send time (Section 10 requirement).
FALLBACK_RECIPIENT_EMAILS=compliance@yourcompany.com
